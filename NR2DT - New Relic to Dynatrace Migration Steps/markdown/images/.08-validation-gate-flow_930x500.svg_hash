<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 930 500" font-family="Inter, system-ui, sans-serif">
  <rect width="930" height="500" fill="#0F172A"/>
  <text x="465" y="36" text-anchor="middle" fill="#F8FAFC" font-size="22" font-weight="700">Validation Gate Decision Flow (Step 8)</text>
  <text x="465" y="60" text-anchor="middle" fill="#94A3B8" font-size="13">Three tiers · all must pass · failure routes back to the responsible step</text>

  <defs>
    <marker id="vg-arr" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#73BE28"/>
    </marker>
    <marker id="vg-fail" viewBox="0 0 10 10" refX="10" refY="5" markerWidth="6" markerHeight="6" orient="auto-start-reverse">
      <path d="M 0 0 L 10 5 L 0 10 z" fill="#DE350B"/>
    </marker>
  </defs>

  <!-- Start -->
  <ellipse cx="100" cy="250" rx="55" ry="30" fill="#334155" stroke="#64748B"/>
  <text x="100" y="247" text-anchor="middle" fill="#F8FAFC" font-size="11" font-weight="700">Migrated</text>
  <text x="100" y="260" text-anchor="middle" fill="#F8FAFC" font-size="11" font-weight="700">artifact</text>

  <!-- Tier 1 -->
  <rect x="200" y="200" width="160" height="100" fill="#1496FF" opacity="0.15" stroke="#1496FF" stroke-width="2" rx="6"/>
  <text x="280" y="225" text-anchor="middle" fill="#BFDBFE" font-size="13" font-weight="700">Tier 1: Syntax</text>
  <text x="280" y="245" text-anchor="middle" fill="#94A3B8" font-size="10">DQL parses?</text>
  <text x="280" y="265" text-anchor="middle" fill="#DBEAFE" font-size="10">Auto-fixer retries</text>
  <text x="280" y="285" text-anchor="middle" fill="#94A3B8" font-size="10">~milliseconds</text>

  <!-- Tier 2 -->
  <rect x="400" y="200" width="160" height="100" fill="#A78BFA" opacity="0.15" stroke="#A78BFA" stroke-width="2" rx="6"/>
  <text x="480" y="225" text-anchor="middle" fill="#DDD6FE" font-size="13" font-weight="700">Tier 2: Tenant</text>
  <text x="480" y="245" text-anchor="middle" fill="#94A3B8" font-size="10">Refs exist?</text>
  <text x="480" y="265" text-anchor="middle" fill="#EDE9FE" font-size="10">Metrics · entities ·</text>
  <text x="480" y="278" text-anchor="middle" fill="#EDE9FE" font-size="10">buckets · attributes</text>

  <!-- Tier 3 -->
  <rect x="600" y="200" width="160" height="100" fill="#73BE28" opacity="0.15" stroke="#73BE28" stroke-width="2" rx="6"/>
  <text x="680" y="225" text-anchor="middle" fill="#D9F99D" font-size="13" font-weight="700">Tier 3: Behavioral</text>
  <text x="680" y="245" text-anchor="middle" fill="#94A3B8" font-size="10">NR vs DT diff?</text>
  <text x="680" y="265" text-anchor="middle" fill="#ECFCCB" font-size="10">Same data shape</text>
  <text x="680" y="278" text-anchor="middle" fill="#ECFCCB" font-size="10">within tolerance</text>

  <!-- Pass terminus -->
  <ellipse cx="850" cy="250" rx="60" ry="30" fill="#73BE28" stroke="#86EFAC" stroke-width="2"/>
  <text x="850" y="247" text-anchor="middle" fill="#0F172A" font-size="11" font-weight="700">Cutover</text>
  <text x="850" y="260" text-anchor="middle" fill="#0F172A" font-size="11" font-weight="700">ready</text>

  <!-- Pass arrows -->
  <g stroke="#73BE28" stroke-width="2.5" fill="none">
    <line x1="155" y1="250" x2="200" y2="250" marker-end="url(#vg-arr)"/>
    <line x1="360" y1="250" x2="400" y2="250" marker-end="url(#vg-arr)"/>
    <line x1="560" y1="250" x2="600" y2="250" marker-end="url(#vg-arr)"/>
    <line x1="760" y1="250" x2="790" y2="250" marker-end="url(#vg-arr)"/>
  </g>

  <!-- Failure routing -->
  <g font-size="10">
    <!-- T1 fail → Step 4 -->
    <rect x="200" y="350" width="160" height="60" fill="#1E293B" stroke="#DE350B" rx="5"/>
    <text x="280" y="370" text-anchor="middle" fill="#FCA5A5" font-weight="600">FAIL → return to</text>
    <text x="280" y="386" text-anchor="middle" fill="#FECACA">NR2DT-04 Translate</text>
    <text x="280" y="402" text-anchor="middle" fill="#94A3B8" font-size="9">re-translate with manual review</text>

    <!-- T2 fail → Step 3 or 5 -->
    <rect x="400" y="350" width="160" height="60" fill="#1E293B" stroke="#DE350B" rx="5"/>
    <text x="480" y="370" text-anchor="middle" fill="#FCA5A5" font-weight="600">FAIL → return to</text>
    <text x="480" y="386" text-anchor="middle" fill="#FECACA">NR2DT-03 Design or 05</text>
    <text x="480" y="402" text-anchor="middle" fill="#94A3B8" font-size="9">prerequisites missing</text>

    <!-- T3 fail → Step 5/6/7 -->
    <rect x="600" y="350" width="160" height="60" fill="#1E293B" stroke="#DE350B" rx="5"/>
    <text x="680" y="370" text-anchor="middle" fill="#FCA5A5" font-weight="600">FAIL → return to</text>
    <text x="680" y="386" text-anchor="middle" fill="#FECACA">component migration step</text>
    <text x="680" y="402" text-anchor="middle" fill="#94A3B8" font-size="9">tune translation / reformulate</text>
  </g>

  <!-- Failure arrows down -->
  <g stroke="#DE350B" stroke-width="1.8" fill="none" stroke-dasharray="4,2">
    <line x1="280" y1="300" x2="280" y2="350" marker-end="url(#vg-fail)"/>
    <line x1="480" y1="300" x2="480" y2="350" marker-end="url(#vg-fail)"/>
    <line x1="680" y1="300" x2="680" y2="350" marker-end="url(#vg-fail)"/>
  </g>

  <!-- Tolerance reminder -->
  <text x="465" y="450" text-anchor="middle" fill="#94A3B8" font-size="11">Tier 3 tolerance: dashboards ±5% · alerts ±10% (dual-run) · SLOs ±0.5% · synthetics ±0.5% · logs ±5%</text>
  <text x="465" y="470" text-anchor="middle" fill="#FCD34D" font-size="11" font-style="italic">Skipping Tier 3 is the most common error — syntactically valid DQL can still produce wrong numbers.</text>
</svg>
