<svg xmlns="http://www.w3.org/2000/svg" width="700" height="300" viewBox="0 0 700 300">
  <defs>
    <linearGradient id="bgGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#0f172a"/>
      <stop offset="100%" style="stop-color:#1e293b"/>
    </linearGradient>
    <filter id="shadow" x="-20%" y="-20%" width="140%" height="140%">
      <feDropShadow dx="2" dy="4" stdDeviation="4" flood-opacity="0.3"/>
    </filter>
    <marker id="arrowhead" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#64748b"/>
    </marker>
  </defs>

  <!-- Background -->
  <rect width="700" height="300" fill="url(#bgGrad)"/>

  <!-- Title -->
  <text x="350" y="30" text-anchor="middle" fill="#f8fafc" font-family="Arial, sans-serif" font-size="18" font-weight="bold">Agent Migration Sequence</text>

  <!-- Step 1: Deploy ActiveGate -->
  <g transform="translate(30, 60)">
    <rect width="120" height="100" rx="8" fill="#14b8a6" filter="url(#shadow)"/>
    <circle cx="60" cy="25" r="18" fill="white" opacity="0.2"/>
    <text x="60" y="32" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">1</text>
    <text x="60" y="58" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Deploy</text>
    <text x="60" y="73" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">ActiveGate</text>
    <text x="60" y="90" text-anchor="middle" fill="#a7f3d0" font-family="Arial, sans-serif" font-size="9">(if needed)</text>
  </g>

  <!-- Arrow 1 -->
  <path d="M155 110 L175 110" stroke="#64748b" stroke-width="2" fill="none" marker-end="url(#arrowhead)"/>

  <!-- Step 2: Migrate Non-Prod -->
  <g transform="translate(160, 60)">
    <rect width="120" height="100" rx="8" fill="#3b82f6" filter="url(#shadow)"/>
    <circle cx="60" cy="25" r="18" fill="white" opacity="0.2"/>
    <text x="60" y="32" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">2</text>
    <text x="60" y="58" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Migrate</text>
    <text x="60" y="73" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Non-Prod</text>
    <text x="60" y="90" text-anchor="middle" fill="#93c5fd" font-family="Arial, sans-serif" font-size="9">Test first</text>
  </g>

  <!-- Arrow 2 -->
  <path d="M285 110 L305 110" stroke="#64748b" stroke-width="2" fill="none" marker-end="url(#arrowhead)"/>

  <!-- Step 3: Validate -->
  <g transform="translate(290, 60)">
    <rect width="120" height="100" rx="8" fill="#a855f7" filter="url(#shadow)"/>
    <circle cx="60" cy="25" r="18" fill="white" opacity="0.2"/>
    <text x="60" y="32" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">3</text>
    <text x="60" y="58" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Validate</text>
    <text x="60" y="73" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Data Flow</text>
    <text x="60" y="90" text-anchor="middle" fill="#d8b4fe" font-family="Arial, sans-serif" font-size="9">Run DQL checks</text>
  </g>

  <!-- Arrow 3 -->
  <path d="M415 110 L435 110" stroke="#64748b" stroke-width="2" fill="none" marker-end="url(#arrowhead)"/>

  <!-- Step 4: Migrate Prod -->
  <g transform="translate(420, 60)">
    <rect width="120" height="100" rx="8" fill="#f97316" filter="url(#shadow)"/>
    <circle cx="60" cy="25" r="18" fill="white" opacity="0.2"/>
    <text x="60" y="32" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">4</text>
    <text x="60" y="58" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Migrate</text>
    <text x="60" y="73" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Production</text>
    <text x="60" y="90" text-anchor="middle" fill="#fed7aa" font-family="Arial, sans-serif" font-size="9">Maintenance window</text>
  </g>

  <!-- Arrow 4 -->
  <path d="M545 110 L565 110" stroke="#64748b" stroke-width="2" fill="none" marker-end="url(#arrowhead)"/>

  <!-- Step 5: Final Validation -->
  <g transform="translate(550, 60)">
    <rect width="120" height="100" rx="8" fill="#22c55e" filter="url(#shadow)"/>
    <circle cx="60" cy="25" r="18" fill="white" opacity="0.2"/>
    <text x="60" y="32" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="16" font-weight="bold">5</text>
    <text x="60" y="58" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Final</text>
    <text x="60" y="73" text-anchor="middle" fill="white" font-family="Arial, sans-serif" font-size="11" font-weight="bold">Validation</text>
    <text x="60" y="90" text-anchor="middle" fill="#bbf7d0" font-family="Arial, sans-serif" font-size="9">Sign-off</text>
  </g>

  <!-- Key Actions Section -->
  <g transform="translate(30, 185)">
    <rect width="640" height="95" rx="8" fill="#1e293b" stroke="#334155" stroke-width="1"/>
    <text x="320" y="22" text-anchor="middle" fill="#f8fafc" font-family="Arial, sans-serif" font-size="12" font-weight="bold">Key Actions at Each Step</text>

    <!-- Step details -->
    <g transform="translate(20, 40)">
      <circle cx="5" cy="8" r="4" fill="#14b8a6"/>
      <text x="15" y="12" fill="#94a3b8" font-family="Arial, sans-serif" font-size="10">1. Install Environment AG, verify connectivity to SaaS</text>

      <circle cx="5" cy="28" r="4" fill="#3b82f6"/>
      <text x="15" y="32" fill="#94a3b8" font-family="Arial, sans-serif" font-size="10">2. Reconfigure OneAgents: oneagentctl --set-server, --set-tenant-token</text>

      <circle cx="5" cy="48" r="4" fill="#a855f7"/>
      <text x="15" y="52" fill="#94a3b8" font-family="Arial, sans-serif" font-size="10">3. Run DQL queries to verify hosts, services, metrics are flowing</text>

      <circle cx="5" cy="68" r="4" fill="#22c55e"/>
      <text x="15" y="72" fill="#94a3b8" font-family="Arial, sans-serif" font-size="10">4-5. Apply same process to production, then full validation and stakeholder sign-off</text>
    </g>
  </g>
</svg>
