<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 900 490">
  <defs>
    <linearGradient id="pProblemGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#f59e0b;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#d97706;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="pStepGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#3b82f6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#2563eb;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="pSolutionGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#10b981;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#059669;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="pCategoryGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#8b5cf6;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#7c3aed;stop-opacity:1" />
    </linearGradient>
    <linearGradient id="pWarningGrad" x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#ef4444;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#dc2626;stop-opacity:1" />
    </linearGradient>
    <filter id="pShadow">
      <feDropShadow dx="2" dy="2" stdDeviation="3" flood-opacity="0.15"/>
    </filter>
    <marker id="pArrow" markerWidth="10" markerHeight="7" refX="9" refY="3.5" orient="auto">
      <polygon points="0 0, 10 3.5, 0 7" fill="#64748b"/>
    </marker>
  </defs>

  <!-- Background -->
  <rect width="900" height="490" fill="#0f172a" rx="10"/>

  <!-- Title -->
  <text x="450" y="28" font-family="system-ui, -apple-system, sans-serif" font-size="18" font-weight="bold" fill="#f1f5f9" text-anchor="middle">Decision Tree 4: Performance Problems</text>

  <!-- Problem Box -->
  <rect x="250" y="40" width="400" height="42" rx="8" fill="url(#pProblemGrad)" filter="url(#pShadow)"/>
  <text x="450" y="58" font-family="system-ui, sans-serif" font-size="13" font-weight="bold" fill="#fff" text-anchor="middle">Slow processing, delayed logs, or high costs</text>
  <text x="450" y="74" font-family="system-ui, sans-serif" font-size="10" fill="rgba(255,255,255,0.8)" text-anchor="middle">Query latency &gt; 5 min | Pipeline time &gt; 100ms | Timeouts</text>

  <!-- Arrow to Step 1 -->
  <line x1="450" y1="82" x2="450" y2="98" stroke="#64748b" stroke-width="2" marker-end="url(#pArrow)"/>

  <!-- Step 1: Identify Bottleneck -->
  <rect x="250" y="102" width="400" height="40" rx="8" fill="url(#pStepGrad)" filter="url(#pShadow)"/>
  <circle cx="278" cy="122" r="13" fill="rgba(255,255,255,0.2)"/>
  <text x="278" y="127" font-family="system-ui, sans-serif" font-size="13" font-weight="bold" fill="#fff" text-anchor="middle">1</text>
  <text x="470" y="117" font-family="system-ui, sans-serif" font-size="13" font-weight="bold" fill="#fff" text-anchor="middle">Identify the bottleneck</text>
  <text x="470" y="133" font-family="system-ui, sans-serif" font-size="10" fill="rgba(255,255,255,0.8)" text-anchor="middle">Which pipeline is slowest? What's causing delays?</text>

  <!-- Warning about NULL fields -->
  <rect x="670" y="102" width="200" height="40" rx="6" fill="url(#pWarningGrad)" opacity="0.9"/>
  <text x="770" y="118" font-family="system-ui, sans-serif" font-size="10" font-weight="bold" fill="#fff" text-anchor="middle">⚠️ NOTE</text>
  <text x="770" y="133" font-family="system-ui, sans-serif" font-size="10" fill="rgba(255,255,255,0.9)" text-anchor="middle">processing_time_ms = NULL</text>

  <!-- Arrow to Step 2 -->
  <line x1="450" y1="142" x2="450" y2="158" stroke="#64748b" stroke-width="2" marker-end="url(#pArrow)"/>

  <!-- Step 2: Optimize Processing -->
  <rect x="300" y="162" width="300" height="32" rx="8" fill="url(#pStepGrad)" filter="url(#pShadow)"/>
  <circle cx="328" cy="178" r="13" fill="rgba(255,255,255,0.2)"/>
  <text x="328" y="183" font-family="system-ui, sans-serif" font-size="13" font-weight="bold" fill="#fff" text-anchor="middle">2</text>
  <text x="470" y="183" font-family="system-ui, sans-serif" font-size="13" font-weight="bold" fill="#fff" text-anchor="middle">Optimize based on issue type</text>

  <!-- Three branches from Step 2 -->
  <line x1="370" y1="194" x2="370" y2="206" stroke="#64748b" stroke-width="2"/>
  <line x1="370" y1="206" x2="150" y2="206" stroke="#64748b" stroke-width="2"/>
  <line x1="150" y1="206" x2="150" y2="212" stroke="#64748b" stroke-width="2" marker-end="url(#pArrow)"/>

  <line x1="450" y1="194" x2="450" y2="212" stroke="#64748b" stroke-width="2" marker-end="url(#pArrow)"/>

  <line x1="530" y1="194" x2="530" y2="206" stroke="#64748b" stroke-width="2"/>
  <line x1="530" y1="206" x2="750" y2="206" stroke="#64748b" stroke-width="2"/>
  <line x1="750" y1="206" x2="750" y2="212" stroke="#64748b" stroke-width="2" marker-end="url(#pArrow)"/>

  <!-- Category 1: High Volume Issues -->
  <rect x="20" y="216" width="270" height="150" rx="8" fill="url(#pCategoryGrad)" filter="url(#pShadow)"/>
  <text x="155" y="236" font-family="system-ui, sans-serif" font-size="12" font-weight="bold" fill="#fff" text-anchor="middle">High Volume Issues</text>
  <rect x="32" y="244" width="246" height="112" rx="6" fill="rgba(255,255,255,0.1)"/>
  <text x="44" y="261" font-family="system-ui, sans-serif" font-size="10" font-weight="bold" fill="#a5f3fc">Solutions:</text>
  <text x="44" y="278" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Drop DEBUG/health checks early</text>
  <text x="44" y="293" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Reduce parsing complexity</text>
  <text x="44" y="308" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Avoid expensive replaceAll</text>
  <text x="44" y="323" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Use sampling for high-volume</text>
  <text x="44" y="346" font-family="system-ui, sans-serif" font-size="10" fill="#86efac">Expected: 60-90% reduction</text>

  <!-- Category 2: Cardinality Explosion -->
  <rect x="310" y="216" width="270" height="150" rx="8" fill="url(#pCategoryGrad)" filter="url(#pShadow)"/>
  <text x="445" y="236" font-family="system-ui, sans-serif" font-size="12" font-weight="bold" fill="#fff" text-anchor="middle">Cardinality Explosion</text>
  <rect x="322" y="244" width="246" height="112" rx="6" fill="rgba(255,255,255,0.1)"/>
  <text x="334" y="261" font-family="system-ui, sans-serif" font-size="10" font-weight="bold" fill="#fcd34d">Symptoms:</text>
  <text x="334" y="278" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Millions of time series</text>
  <text x="334" y="293" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• High DDU costs</text>
  <text x="334" y="311" font-family="system-ui, sans-serif" font-size="10" font-weight="bold" fill="#a5f3fc">Solutions:</text>
  <text x="334" y="326" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Bucket high-cardinality fields</text>
  <text x="334" y="341" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Remove user_id dimensions</text>
  <text x="334" y="349" font-family="system-ui, sans-serif" font-size="10" fill="#86efac">Target: &lt;10K series/metric</text>

  <!-- Category 3: Cost Optimization -->
  <rect x="600" y="216" width="280" height="150" rx="8" fill="url(#pCategoryGrad)" filter="url(#pShadow)"/>
  <text x="740" y="236" font-family="system-ui, sans-serif" font-size="12" font-weight="bold" fill="#fff" text-anchor="middle">Cost Optimization</text>
  <rect x="612" y="244" width="256" height="112" rx="6" fill="rgba(255,255,255,0.1)"/>
  <text x="624" y="261" font-family="system-ui, sans-serif" font-size="10" font-weight="bold" fill="#a5f3fc">Strategies:</text>
  <text x="624" y="278" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Drop DEBUG/TRACE logs</text>
  <text x="624" y="293" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Reduce dev retention</text>
  <text x="624" y="308" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">• Extract metrics instead</text>
  <text x="624" y="328" font-family="system-ui, sans-serif" font-size="10" font-weight="bold" fill="#fcd34d">ROI Example:</text>
  <text x="624" y="343" font-family="system-ui, sans-serif" font-size="10" fill="#e2e8f0">100GB logs → Metrics = 99.9% cost savings</text>

  <!-- Optimization Examples Section -->
  <rect x="20" y="376" width="860" height="105" rx="10" fill="#1e293b" stroke="#334155" stroke-width="1"/>
  <text x="450" y="396" font-family="system-ui, sans-serif" font-size="13" font-weight="bold" fill="#f1f5f9" text-anchor="middle">Optimization Patterns</text>

  <!-- Pattern 1: Filter First -->
  <rect x="35" y="404" width="265" height="68" rx="6" fill="#334155"/>
  <text x="167" y="420" font-family="system-ui, sans-serif" font-size="11" font-weight="bold" fill="#10b981" text-anchor="middle">✓ Filter First, Then Parse</text>
  <text x="48" y="437" font-family="monospace" font-size="9" fill="#94a3b8">❌ SLOW: </text><text x="108" y="437" font-family="monospace" font-size="9" fill="#fca5a5">parse | filter ERROR</text>
  <text x="48" y="453" font-family="monospace" font-size="9" fill="#94a3b8">✓ FAST: </text><text x="102" y="453" font-family="monospace" font-size="9" fill="#86efac">filter ERROR | parse</text>
  <text x="48" y="467" font-family="system-ui, sans-serif" font-size="9" fill="#64748b">Reduces parse load 70%+</text>

  <!-- Pattern 2: Combine Regex -->
  <rect x="318" y="404" width="265" height="68" rx="6" fill="#334155"/>
  <text x="450" y="420" font-family="system-ui, sans-serif" font-size="11" font-weight="bold" fill="#10b981" text-anchor="middle">✓ Combine Regex Patterns</text>
  <text x="331" y="437" font-family="monospace" font-size="9" fill="#94a3b8">❌ </text><text x="348" y="437" font-family="monospace" font-size="9" fill="#fca5a5">replaceAll(p1) | replaceAll(p2)</text>
  <text x="331" y="453" font-family="monospace" font-size="9" fill="#94a3b8">✓  </text><text x="348" y="453" font-family="monospace" font-size="9" fill="#86efac">replaceAll("(p1|p2)", "X")</text>
  <text x="331" y="467" font-family="system-ui, sans-serif" font-size="9" fill="#64748b">Single pass = 50-80% faster</text>

  <!-- Pattern 3: Bucketing -->
  <rect x="601" y="404" width="265" height="68" rx="6" fill="#334155"/>
  <text x="733" y="420" font-family="system-ui, sans-serif" font-size="11" font-weight="bold" fill="#10b981" text-anchor="middle">✓ Bucket High Cardinality</text>
  <text x="614" y="437" font-family="monospace" font-size="9" fill="#94a3b8">❌ BAD:  </text><text x="670" y="437" font-family="monospace" font-size="9" fill="#fca5a5">duration_ms (infinite)</text>
  <text x="614" y="453" font-family="monospace" font-size="9" fill="#94a3b8">✓ GOOD: </text><text x="670" y="453" font-family="monospace" font-size="9" fill="#86efac">duration_bucket (4 values)</text>
  <text x="614" y="467" font-family="system-ui, sans-serif" font-size="9" fill="#64748b">99.96% series reduction</text>
</svg>
